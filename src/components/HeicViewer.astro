---
/**
 * HEIC Viewer — preview an iPhone HEIC photo without converting + downloading.
 * Decodes via the existing libheif worker, renders to a PNG blob URL.
 */
---

<section class="w-full max-w-3xl mx-auto" id="viewer-app">
  <div
    id="viewer-dropzone"
    data-state="idle"
    class="relative border-2 border-dashed border-[var(--color-border)] rounded-2xl p-10 sm:p-14 bg-[var(--color-surface)] text-center cursor-pointer transition-all"
    tabindex="0"
    role="button"
    aria-label="Drop a HEIC file to preview"
  >
    <div class="flex flex-col items-center gap-3 pointer-events-none">
      <svg viewBox="0 0 64 64" class="w-14 h-14 text-[var(--color-accent)]" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="6" y="10" width="52" height="44" rx="4"/>
        <circle cx="22" cy="26" r="4"/>
        <path d="M6 44l14-14 12 12 8-8 14 14"/>
      </svg>
      <p class="text-lg sm:text-xl font-semibold">Drop a HEIC photo to preview</p>
      <p class="text-sm text-[var(--color-muted)]">
        or <span class="text-[var(--color-accent)] underline">tap to pick a photo</span>
      </p>
    </div>
    <input
      id="viewer-file-input"
      type="file"
      accept=".heic,.heif,image/heic,image/heif"
      class="absolute inset-0 w-full h-full opacity-0 cursor-pointer"
      aria-label="Pick a HEIC file to view"
    />
  </div>

  <div id="viewer-status" class="hidden mt-4 text-sm text-[var(--color-muted)] text-center" aria-live="polite"></div>

  <div id="viewer-error" class="hidden mt-4 p-3 rounded-md border border-[var(--color-error)] bg-[var(--color-error)]/10 text-sm text-[var(--color-error)]" role="alert"></div>

  <figure id="viewer-result" class="hidden mt-6">
    <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-3 flex items-center justify-center">
      <img id="viewer-image" alt="" class="max-w-full h-auto rounded-md" />
    </div>
    <figcaption class="mt-3 flex flex-wrap items-center justify-between gap-3 text-sm text-[var(--color-muted)]">
      <span id="viewer-meta"></span>
      <div class="flex gap-2">
        <button
          id="viewer-pick-another"
          type="button"
          class="px-3 py-1.5 rounded-md border border-[var(--color-border)] hover:bg-[var(--color-bg)] text-xs font-semibold transition-colors"
        >
          View another
        </button>
        <a
          id="viewer-convert-link"
          href="/"
          class="px-3 py-1.5 rounded-md bg-[var(--color-accent)] text-[var(--color-accent-fg)] hover:bg-[var(--color-accent-hover)] text-xs font-semibold transition-colors"
        >
          Convert this photo →
        </a>
      </div>
    </figcaption>
  </figure>
</section>

<style>
  #viewer-dropzone[data-state="active"] {
    border-color: var(--color-accent);
    background-color: color-mix(in srgb, var(--color-accent) 8%, var(--color-surface));
  }
  #viewer-dropzone:focus-visible {
    border-color: var(--color-accent);
    outline-offset: 4px;
  }
</style>

<script>
  import("./HeicViewer.script.ts");
</script>
