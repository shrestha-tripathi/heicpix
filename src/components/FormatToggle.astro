---
/**
 * Format + quality controls for HEIC pipelines.
 *
 * Renders:
 *   1. Four-format toggle: JPG / PNG / WebP / AVIF
 *      - AVIF auto-disables if the browser doesn't encode AVIF
 *        (Chrome 124+ only as of 2026)
 *      - Active button persists to localStorage under `${storageNs}:${namespace}:format`
 *   2. Quality slider for lossy formats (JPG/WebP/AVIF)
 *      - Hidden when PNG is active (lossless = no quality knob)
 *      - Persists under `${storageNs}:${namespace}:quality`
 *      - Range 0.30..1.00, step 0.05
 *      - Default 0.92 (matches iOS native export)
 *
 * Both controls dispatch `heicpix:${namespace}-format-change` and
 * `heicpix:${namespace}-quality-change` CustomEvents so the page's
 * pipeline (converter / stripper / etc) can react.
 *
 * Each namespace gets its own DOM ids, storage keys, dataset attrs,
 * and event names — so multiple toggles can coexist on different pages
 * (or even on the same page) without sharing state.
 *
 * Why these together: they're conceptually one widget — "how do you
 * want the output." Keeping them in one Astro component avoids
 * orchestrating two scripts.
 */
import { site } from "../site.config";

interface Props {
  /**
   * Namespace for storage keys, DOM ids, dataset attributes, and event names.
   * Defaults to "format" (the original main-converter namespace, kept for
   * backwards compatibility with existing call sites).
   *
   * Examples:
   *   namespace="format"        → main converter (default)
   *   namespace="strip-format"  → strip-exif tool
   */
  namespace?: string;
}

const { namespace = "format" } = Astro.props as Props;
// For namespace="format" (the default / main converter), preserve the
// original DOM ids verbatim so existing CSS / DevTools muscle memory
// keeps working. Other namespaces get prefixed ids.
const isDefault = namespace === "format";
const toggleId = isDefault ? "format-toggle" : `${namespace}-toggle`;
const qualityWrapId = isDefault ? "quality-control" : `${namespace}-quality-control`;
const sliderId = isDefault ? "quality-slider" : `${namespace}-quality-slider`;
const valueId = isDefault ? "quality-value" : `${namespace}-quality-value`;
const formatEvent = isDefault
  ? "heicpix:format-change"
  : `heicpix:${namespace}-change`;
const qualityEvent = isDefault
  ? "heicpix:quality-change"
  : `heicpix:${namespace}-quality-change`;
// dataset attr names need to be valid camelCase. For "format" → "format",
// for "strip-format" → "stripFormat".
function toDatasetName(ns: string, suffix: string): string {
  if (ns === "format") return suffix; // "format" or "quality"
  // Convert kebab → camel and append suffix (capitalized)
  const camel = ns.replace(/-([a-z])/g, (_, c) => c.toUpperCase());
  return suffix === "format" ? camel : `${camel}${suffix[0].toUpperCase()}${suffix.slice(1)}`;
}
const formatDatasetAttr = toDatasetName(namespace, "format");
const qualityDatasetAttr = toDatasetName(namespace, "quality");
const formatStorageKey = isDefault
  ? `${site.storageNs}:format`
  : `${site.storageNs}:${namespace}`;
const qualityStorageKey = isDefault
  ? `${site.storageNs}:quality`
  : `${site.storageNs}:${namespace}-quality`;
---

<div class="space-y-3" data-format-widget={namespace}>
  <!-- Format row -->
  <div
    id={toggleId}
    role="radiogroup"
    aria-label="Output format"
    class="inline-flex flex-wrap rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-1 text-sm font-semibold gap-0 format-toggle-group"
  >
    <button
      type="button"
      role="radio"
      aria-checked="true"
      data-format="jpg"
      class="px-4 py-1.5 rounded-md transition-colors"
    >
      → JPG
    </button>
    <button
      type="button"
      role="radio"
      aria-checked="false"
      data-format="png"
      class="px-4 py-1.5 rounded-md transition-colors"
    >
      → PNG
    </button>
    <button
      type="button"
      role="radio"
      aria-checked="false"
      data-format="webp"
      class="px-4 py-1.5 rounded-md transition-colors"
    >
      → WebP
    </button>
    <button
      type="button"
      role="radio"
      aria-checked="false"
      data-format="avif"
      data-needs-probe="true"
      class="px-4 py-1.5 rounded-md transition-colors"
      title="AVIF requires Chrome 124+ or Edge 124+"
    >
      → AVIF
    </button>
  </div>

  <!-- Quality row (hidden when PNG is active) -->
  <div
    id={qualityWrapId}
    class="flex items-center gap-3 text-sm quality-control"
    data-show="true"
  >
    <label for={sliderId} class="text-[var(--color-muted)] font-medium">
      Quality
    </label>
    <input
      id={sliderId}
      type="range"
      min="0.3"
      max="1"
      step="0.05"
      value="0.92"
      class="flex-1 max-w-[160px] accent-[var(--color-accent)] cursor-pointer"
      aria-label="Output quality (lossy formats)"
    />
    <span
      id={valueId}
      class="font-mono text-xs text-[var(--color-fg)] tabular-nums w-8 text-right"
    >
      92%
    </span>
  </div>
</div>

<style>
  /* Scope styles by class so multiple toggles on the same page work. */
  .format-toggle-group button[aria-checked="true"] {
    background-color: var(--color-accent);
    color: var(--color-accent-fg);
  }
  .format-toggle-group button[aria-checked="false"] {
    color: var(--color-muted);
  }
  .format-toggle-group button[aria-checked="false"]:hover:not([disabled]) {
    color: var(--color-fg);
    background-color: var(--color-bg);
  }
  .format-toggle-group button[disabled] {
    opacity: 0.4;
    cursor: not-allowed;
    text-decoration: line-through;
  }
  .quality-control[data-show="false"] {
    display: none;
  }
</style>

<script
  is:inline
  define:vars={{
    toggleId,
    qualityWrapId,
    sliderId,
    valueId,
    formatStorageKey,
    qualityStorageKey,
    formatEvent,
    qualityEvent,
    formatDatasetAttr,
    qualityDatasetAttr,
  }}
>
  (function () {
    const group = document.getElementById(toggleId);
    const qualityWrapEl = document.getElementById(qualityWrapId);
    const slider = document.getElementById(sliderId);
    const valueEl = document.getElementById(valueId);
    if (!group || !qualityWrapEl || !slider || !valueEl) return;

    const buttons = group.querySelectorAll("button[data-format]");
    const valid = new Set(["jpg", "png", "webp", "avif"]);
    const lossy = new Set(["jpg", "webp", "avif"]);

    function readQuality() {
      try {
        const stored = parseFloat(localStorage.getItem(qualityStorageKey));
        if (stored >= 0.3 && stored <= 1) return stored;
      } catch (e) {}
      return 0.92;
    }

    function writeQuality(q) {
      try {
        localStorage.setItem(qualityStorageKey, String(q));
      } catch (e) {}
    }

    function setQuality(q, options) {
      const opts = options || {};
      slider.value = String(q);
      valueEl.textContent = Math.round(q * 100) + "%";
      document.documentElement.dataset[qualityDatasetAttr] = String(q);
      writeQuality(q);
      if (!opts.silent) {
        document.dispatchEvent(
          new CustomEvent(qualityEvent, { detail: { quality: q } }),
        );
      }
    }

    function setFormat(format, options) {
      const opts = options || {};
      buttons.forEach((btn) => {
        const matches = btn.dataset.format === format;
        btn.setAttribute("aria-checked", matches ? "true" : "false");
      });
      document.documentElement.dataset[formatDatasetAttr] = format;
      try {
        localStorage.setItem(formatStorageKey, format);
      } catch (e) {}

      // Show/hide quality control based on format
      qualityWrapEl.dataset.show = lossy.has(format) ? "true" : "false";

      if (!opts.silent) {
        document.dispatchEvent(
          new CustomEvent(formatEvent, { detail: { format } }),
        );
      }
    }

    // Hydrate from storage
    let initial = "jpg";
    try {
      const stored = localStorage.getItem(formatStorageKey);
      if (valid.has(stored)) initial = stored;
    } catch (e) {}
    setQuality(readQuality(), { silent: true });
    setFormat(initial, { silent: true });

    // Wire up clicks
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        if (btn.hasAttribute("disabled")) return;
        setFormat(btn.dataset.format);
      });
    });

    // Wire up slider
    slider.addEventListener("input", () => {
      setQuality(parseFloat(slider.value));
    });

    // Probe AVIF support asynchronously — disable the button if unsupported.
    // We do this here (not in the worker module) so the probe runs before
    // libheif is even loaded. Use the main thread's OffscreenCanvas.
    (async () => {
      const avifBtn = group.querySelector('button[data-format="avif"]');
      if (!avifBtn) return;
      try {
        // Some browsers don't have OffscreenCanvas in the main thread —
        // use a plain HTMLCanvas as fallback.
        let canvas;
        if (typeof OffscreenCanvas !== "undefined") {
          canvas = new OffscreenCanvas(1, 1);
        } else {
          canvas = document.createElement("canvas");
          canvas.width = canvas.height = 1;
        }
        const ctx = canvas.getContext("2d");
        ctx.fillStyle = "#000";
        ctx.fillRect(0, 0, 1, 1);

        let blob;
        if (canvas.convertToBlob) {
          blob = await canvas.convertToBlob({ type: "image/avif", quality: 0.5 });
        } else {
          blob = await new Promise((resolve) =>
            canvas.toBlob(resolve, "image/avif", 0.5),
          );
        }
        const supported = blob && blob.type === "image/avif";
        if (!supported) {
          avifBtn.setAttribute("disabled", "");
          avifBtn.setAttribute(
            "title",
            "AVIF encoding requires Chrome 124+ or Edge 124+. Try WebP — almost as small, universally supported.",
          );
          // If AVIF was the persisted choice, fall back to WebP
          if (document.documentElement.dataset[formatDatasetAttr] === "avif") {
            setFormat("webp");
          }
        }
      } catch (e) {
        avifBtn.setAttribute("disabled", "");
      }
    })();
  })();
</script>
