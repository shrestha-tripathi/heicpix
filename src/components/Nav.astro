---
import { site } from "../site.config";
import { b } from "../lib/baseUrl";

const navLinks = [
  { href: b("/"), label: "Convert" },
  { href: b("/how-it-works"), label: "How it works" },
  { href: b("/faq"), label: "FAQ" },
  { href: b("/privacy"), label: "Privacy" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header
  class="sticky top-0 z-20 bg-[var(--color-bg)]/85 backdrop-blur-md border-b border-[var(--color-border)]"
>
  <nav class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between gap-4">
    <!-- Logo / wordmark -->
    <a
      href={b("/")}
      class="flex items-center gap-2 text-[var(--color-fg)] no-underline font-extrabold tracking-tight text-lg"
      aria-label={`${site.name} home`}
    >
      <svg
        viewBox="0 0 32 32"
        class="w-6 h-6 text-[var(--color-accent)]"
        aria-hidden="true"
      >
        <!-- Pixel grid icon: 3x3 squares with one accent -->
        <rect x="2" y="2" width="8" height="8" rx="1.5" fill="currentColor" opacity="0.4"/>
        <rect x="12" y="2" width="8" height="8" rx="1.5" fill="currentColor" opacity="0.6"/>
        <rect x="22" y="2" width="8" height="8" rx="1.5" fill="currentColor" opacity="0.4"/>
        <rect x="2" y="12" width="8" height="8" rx="1.5" fill="currentColor" opacity="0.6"/>
        <rect x="12" y="12" width="8" height="8" rx="1.5" fill="currentColor"/>
        <rect x="22" y="12" width="8" height="8" rx="1.5" fill="currentColor" opacity="0.6"/>
        <rect x="2" y="22" width="8" height="8" rx="1.5" fill="currentColor" opacity="0.4"/>
        <rect x="12" y="22" width="8" height="8" rx="1.5" fill="currentColor" opacity="0.6"/>
        <rect x="22" y="22" width="8" height="8" rx="1.5" fill="currentColor" opacity="0.4"/>
      </svg>
      {site.name}
    </a>

    <!-- Links (desktop) -->
    <ul class="hidden sm:flex items-center gap-1 text-sm">
      {
        navLinks.map((link) => {
          const isActive = currentPath === link.href.replace(/\/$/, "") || currentPath === link.href;
          return (
            <li>
              <a
                href={link.href}
                class:list={[
                  "px-3 py-1.5 rounded-md transition-colors",
                  isActive
                    ? "text-[var(--color-fg)] bg-[var(--color-surface)] font-semibold"
                    : "text-[var(--color-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-surface)]",
                ]}
              >
                {link.label}
              </a>
            </li>
          );
        })
      }
    </ul>

    <!-- Theme toggle -->
    <button
      id="theme-toggle"
      type="button"
      class="p-2 rounded-md text-[var(--color-muted)] hover:text-[var(--color-fg)] hover:bg-[var(--color-surface)] transition-colors"
      aria-label="Toggle dark mode"
      title="Toggle theme"
    >
      <!-- Sun (shown in dark mode = "switch to light") -->
      <svg
        id="theme-icon-sun"
        viewBox="0 0 24 24"
        class="w-5 h-5 hidden dark:block"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="4" />
        <path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5L19 19M5 19l1.5-1.5M17.5 6.5L19 5"/>
      </svg>
      <!-- Moon (shown in light mode = "switch to dark") -->
      <svg
        id="theme-icon-moon"
        viewBox="0 0 24 24"
        class="w-5 h-5 dark:hidden"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        aria-hidden="true"
      >
        <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
      </svg>
    </button>
  </nav>
</header>

<script is:inline define:vars={{ storageKey: `${site.storageNs}:theme` }}>
  (function () {
    const btn = document.getElementById("theme-toggle");
    if (!btn) return;

    function getCurrent() {
      return document.documentElement.getAttribute("data-theme") || "dark";
    }

    function applyTheme(theme) {
      document.documentElement.setAttribute("data-theme", theme);
      try {
        localStorage.setItem(storageKey, theme);
      } catch (e) {
        // localStorage disabled (private mode) — toggle still works in-session
      }
      // Update theme-color meta for mobile address bar
      const meta = document.getElementById("theme-color-meta");
      if (meta) {
        meta.setAttribute("content", theme === "dark" ? "#0a0a0a" : "#ffffff");
      }
    }

    // Sync class list for dark:/light: tailwind variants (although we don't
    // use them — pure CSS variable swap is enough — keeping for future)
    btn.addEventListener("click", () => {
      const next = getCurrent() === "dark" ? "light" : "dark";
      applyTheme(next);
    });
  })();
</script>
