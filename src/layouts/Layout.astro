---
import "../styles/global.css";
import { site } from "../site.config";
import { absoluteUrl } from "../lib/baseUrl";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: object | object[];
  noindex?: boolean;
  /** When true, omit Nav + Footer chrome (used by 404 + /share). */
  bare?: boolean;
}

const {
  title = site.tagline,
  description = site.description,
  canonical,
  ogImage = "/og-image.png",
  jsonLd,
  noindex = false,
  bare = false,
} = Astro.props;

const pageTitle = title === site.tagline
  ? `${site.name} — ${site.tagline}`
  : `${title} | ${site.name}`;

const canonicalUrl = canonical ?? absoluteUrl(Astro.url.pathname);
const ogImageUrl = new URL(ogImage, site.url).toString();

// Always include the default Organization + WebSite schemas + any per-page schema
const baseSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: site.org.name,
    url: site.org.url,
    logo: site.org.logo,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name,
    url: site.url,
    description: site.description,
    publisher: {
      "@type": "Organization",
      name: site.org.name,
      url: site.org.url,
    },
  },
];

// Auto-breadcrumb: Home -> <title> on every non-home page — BUT only when the
// page hasn't already supplied its own BreadcrumbList via jsonLd. All 28 current
// interior pages do (via lib/breadcrumb.ts), so this acts as a DRY safety net:
// any future page that forgets a crumb trail auto-gets one, with NO duplicates
// on existing pages. Skipped on the homepage where a breadcrumb would be noise.
const jsonLdArr = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const hasOwnBreadcrumb = jsonLdArr.some(
  (s) => (s as { "@type"?: string })["@type"] === "BreadcrumbList",
);
const breadcrumbSchema =
  title && Astro.url.pathname !== "/" && !hasOwnBreadcrumb
    ? {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
          { "@type": "ListItem", position: 1, name: "Home", item: absoluteUrl("/") },
          { "@type": "ListItem", position: 2, name: title, item: canonicalUrl },
        ],
      }
    : null;

const allSchemas = [
  ...baseSchemas,
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
  ...jsonLdArr,
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

    {/* Theme bootstrap — runs BEFORE stylesheet to prevent FOUC */}
    <script is:inline define:vars={{ storageKey: `${site.storageNs}:theme` }}>
      (function () {
        try {
          var stored = localStorage.getItem(storageKey);
          var theme = stored === "light" || stored === "dark" ? stored : "dark";
          document.documentElement.setAttribute("data-theme", theme);
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      })();
    </script>

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {noindex && <meta name="robots" content="noindex,nofollow" />}

    {/* Theme color — dynamically updated by theme toggle script */}
    <meta id="theme-color-meta" name="theme-color" content={site.themeColorDark} />

    {/* Favicons */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={`${site.name} — ${site.tagline}`} />
    <meta property="og:site_name" content={site.name} />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={site.twitter} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {/* JSON-LD structured data */}
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(allSchemas)}
    />

    {/* GA4 — production-only, env-gated */}
    {
      import.meta.env.PROD && site.ga4MeasurementId && (
        <>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${site.ga4MeasurementId}`}
          />
          <script is:inline define:vars={{ id: site.ga4MeasurementId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", id, { anonymize_ip: true });
          </script>
        </>
      )
    }

    {/* Register service worker for Web Share Target (production only). */}
    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker
            .register("/sw.js")
            .catch((err) => console.warn("SW registration failed:", err));
        });
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-[var(--color-bg)] text-[var(--color-fg)]">
    {!bare && <Nav />}
    <main class="flex-1">
      <slot />
    </main>
    {!bare && <Footer />}
  </body>
</html>
