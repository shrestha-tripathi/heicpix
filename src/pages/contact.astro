---
import Layout from "../layouts/Layout.astro";
import { site } from "../site.config";
import { b } from "../lib/baseUrl";
import { breadcrumb } from "../lib/breadcrumb";

/**
 * Contact page — required for AdSense + general trust.
 *
 * Static-site approach: NO form (forms need a serverless backend that
 * would add cost + spam-handling complexity). Instead we surface every
 * way to reach us as clear, copyable links. This is the universal SSG
 * pattern (Stripe, Linear, Vercel docs all do this when their forms
 * aren't critical).
 */

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": `${site.url}/contact#contact`,
  url: `${site.url}/contact`,
  name: `Contact ${site.shortName}`,
  description: `Get in touch with ${site.shortName} — bug reports, feature requests, security disclosures, and general questions.`,
  publisher: { "@id": `${site.url}/#organization` },
};

const githubLabel = site.githubRepo.replace(/^https?:\/\//, "");
const issuesUrl = `${site.githubRepo}/issues/new`;

const breadcrumbLd = breadcrumb({ name: "Contact", path: "/contact" });
---

<Layout
  title={`Contact — get in touch with ${site.shortName}`}
  description={`Reach ${site.shortName} for bug reports, feature requests, security disclosures, partnership inquiries, or general questions. Email and GitHub channels listed.`}
  jsonLd={[contactSchema, breadcrumbLd]}
>
  <div class="max-w-3xl mx-auto px-6 py-12 sm:py-16">
    <header class="mb-10">
      <p class="text-sm text-[var(--color-muted)] mb-2">
        <a href={b("/")} class="hover:text-[var(--color-fg)]">{site.name}</a>
        <span class="mx-1">/</span>
        <span>Contact</span>
      </p>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">
        Get in touch
      </h1>
      <p class="text-lg text-[var(--color-muted)]">
        We read everything. Bug reports get priority. Pick whichever
        channel works best for you.
      </p>
    </header>

    <div class="space-y-4">
      <!-- Email -->
      <section
        class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]"
      >
        <div class="flex items-start gap-4">
          <div
            class="flex items-center justify-center w-11 h-11 rounded-lg bg-[var(--color-accent)]/[0.10] text-[var(--color-accent)] shrink-0"
            aria-hidden="true"
          >
            <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="5" width="18" height="14" rx="2"/>
              <path d="M3 7l9 6 9-6"/>
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <h2 class="text-lg font-bold text-[var(--color-fg)] mb-1">
              Email
            </h2>
            <p class="text-sm text-[var(--color-muted)] mb-3">
              Best for: bug reports, feature requests, general questions,
              partnership inquiries.
            </p>
            <a
              href={`mailto:${site.contactEmail}`}
              class="inline-block font-mono text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] break-all"
            >
              {site.contactEmail}
            </a>
            <p class="text-xs text-[var(--color-muted)] mt-2">
              Typical response time: 2–3 business days.
            </p>
          </div>
        </div>
      </section>

      <!-- GitHub Issues -->
      <section
        class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]"
      >
        <div class="flex items-start gap-4">
          <div
            class="flex items-center justify-center w-11 h-11 rounded-lg bg-[var(--color-accent)]/[0.10] text-[var(--color-accent)] shrink-0"
            aria-hidden="true"
          >
            <svg viewBox="0 0 24 24" class="w-6 h-6" fill="currentColor">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.16c-3.2.69-3.88-1.39-3.88-1.39-.52-1.33-1.28-1.69-1.28-1.69-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.29 1.19-3.09-.12-.29-.52-1.47.11-3.06 0 0 .97-.31 3.18 1.18a11.04 11.04 0 015.79 0c2.21-1.49 3.18-1.18 3.18-1.18.63 1.59.23 2.77.11 3.06.74.8 1.19 1.83 1.19 3.09 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.56 4.57-1.52 7.85-5.83 7.85-10.91C23.5 5.65 18.35.5 12 .5z"/>
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <h2 class="text-lg font-bold text-[var(--color-fg)] mb-1">
              GitHub Issues
            </h2>
            <p class="text-sm text-[var(--color-muted)] mb-3">
              Best for: reproducible bugs, feature proposals, technical
              discussion. The repo is currently private, but we still
              accept issues if you have access — otherwise email is
              equivalent.
            </p>
            <a
              href={issuesUrl}
              rel="noopener"
              class="inline-block font-mono text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] break-all"
            >
              {githubLabel}/issues
            </a>
            <p class="text-xs text-[var(--color-muted)] mt-2">
              If you can include the browser version, file size, and the
              first error from DevTools console, we can usually reproduce
              within a day.
            </p>
          </div>
        </div>
      </section>

      <!-- Security disclosures -->
      <section
        class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]"
      >
        <div class="flex items-start gap-4">
          <div
            class="flex items-center justify-center w-11 h-11 rounded-lg bg-[var(--color-accent)]/[0.10] text-[var(--color-accent)] shrink-0"
            aria-hidden="true"
          >
            <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-12V5l-8-3-8 3v5c0 8 8 12 8 12z"/>
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <h2 class="text-lg font-bold text-[var(--color-fg)] mb-1">
              Security disclosures
            </h2>
            <p class="text-sm text-[var(--color-muted)] mb-3">
              Found something that looks like a security issue (XSS,
              third-party leakage, data exfiltration path)? Email us
              directly with the subject prefix <code class="text-[var(--color-fg)] bg-[var(--color-bg)] px-1.5 py-0.5 rounded text-xs">[Security]</code>
              before disclosing publicly.
            </p>
            <a
              href={`mailto:${site.contactEmail}?subject=%5BSecurity%5D%20`}
              class="inline-block font-mono text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] break-all"
            >
              {site.contactEmail}
            </a>
            <p class="text-xs text-[var(--color-muted)] mt-2">
              We'll acknowledge within 48 hours and coordinate a fix
              timeline before any public disclosure.
            </p>
          </div>
        </div>
      </section>
    </div>

    <section class="mt-16">
      <h2 class="text-xl font-bold mb-4">
        Before you write — check the FAQ
      </h2>
      <p class="text-[var(--color-muted)] leading-relaxed mb-4">
        Most common questions are already answered:
      </p>
      <ul class="space-y-2 text-[var(--color-muted)]">
        <li>
          <a href={b("/faq")} class="text-[var(--color-accent)] hover:underline">
            FAQ
          </a> — 40+ answers about HEIC, conversion, formats, app
          compatibility, privacy.
        </li>
        <li>
          <a href={b("/how-it-works")} class="text-[var(--color-accent)] hover:underline">
            How it works
          </a> — the technical architecture explained.
        </li>
        <li>
          <a href={b("/privacy")} class="text-[var(--color-accent)] hover:underline">
            Privacy by design
          </a> — what we do and don't collect (technical version).
        </li>
        <li>
          <a href={b("/privacy-policy")} class="text-[var(--color-accent)] hover:underline">
            Privacy Policy
          </a> — the formal legal version.
        </li>
      </ul>
    </section>

    <div
      class="mt-12 pt-6 border-t border-[var(--color-border)] text-sm text-[var(--color-muted)]"
    >
      <p>
        Operator: {site.author} ({site.jurisdiction}) ·
        Parent brand: <a
          href={site.org.url}
          class="text-[var(--color-accent)] hover:underline"
          rel="noopener">{site.org.name}</a
        >
      </p>
    </div>
  </div>
</Layout>
