---
import Layout from "../layouts/Layout.astro";
import { site } from "../site.config";
import { b } from "../lib/baseUrl";
import { breadcrumb } from "../lib/breadcrumb";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to attach iPhone HEIC photos in Gmail",
  description: "Gmail attaches HEIC but recipients can't preview it. Convert to JPG in your browser first.",
  totalTime: "PT30S",
  step: [
    { "@type": "HowToStep", position: 1, name: `Open ${site.name}`, text: `Visit ${site.domain}.` },
    { "@type": "HowToStep", position: 2, name: "Drop your HEIC photos", text: "Drag-and-drop or pick from your computer / phone." },
    { "@type": "HowToStep", position: 3, name: "Pick JPG", text: "JPG previews inline in Gmail on every browser and mobile app." },
    { "@type": "HowToStep", position: 4, name: "Attach in Gmail", text: "Drag the JPG into your compose window. Inline preview works for the recipient." },
  ],
};

const breadcrumbLd = breadcrumb({ name: "HEIC for Gmail", path: "/heic-for-gmail" });
---

<Layout
  title="HEIC for Gmail — attach iPhone photos that recipients can preview"
  description="Gmail attaches .heic from iPhone but recipients see 'no preview' on Windows. Convert HEIC to JPG in your browser first. Works in Gmail Web, Gmail Mobile, Outlook recipients."
  jsonLd={[jsonLd, breadcrumbLd]}
>
  <div class="max-w-3xl mx-auto px-6 py-12 sm:py-16">
    <header class="mb-10">
      <p class="text-sm text-[var(--color-muted)] mb-2">
        <a href={b("/")} class="hover:text-[var(--color-fg)]">{site.name}</a>
        <span class="mx-1">/</span>
        <span>HEIC for Gmail</span>
      </p>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">
        Attaching HEIC photos in Gmail
      </h1>
      <p class="text-lg text-[var(--color-muted)]">
        Gmail accepts .heic attachments from your iPhone — but recipients on
        Windows, Android, or older devices can't preview them. Convert to JPG
        first and everyone sees the photo inline.
      </p>
    </header>

    <section class="mb-10">
      <h2 class="text-2xl font-bold mb-4">The fix</h2>
      <p class="text-[var(--color-muted)] leading-relaxed mb-4">
        Drop your HEIC into {site.name}, pick JPG, then attach the converted
        file in Gmail. Works in Gmail Web, Android, iOS, and for recipients
        using Outlook, Yahoo, or any other client.
      </p>
      <a
        href={b("/")}
        class="inline-block px-6 py-3 rounded-lg bg-[var(--color-accent)] text-[var(--color-accent-fg)] font-semibold hover:bg-[var(--color-accent-hover)] transition-colors"
      >
        Convert HEIC for Gmail →
      </a>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-bold mb-4">Why does Gmail not preview HEIC?</h2>
      <p class="text-[var(--color-muted)] leading-relaxed mb-3">
        Gmail's inline image preview is generated server-side using
        Google's image processing pipeline. While Google Photos supports
        HEIC, Gmail's preview pipeline doesn't — attachments show as
        downloadable files instead of inline images.
      </p>
      <p class="text-[var(--color-muted)] leading-relaxed">
        That means recipients can't see the photo without downloading and
        opening separately — and many of them can't even open HEIC after
        downloading (Windows without codec, older Android, work laptops).
      </p>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-bold mb-4">Inline embed in Gmail compose</h2>
      <p class="text-[var(--color-muted)] leading-relaxed mb-3">
        Once converted to JPG, you can also <em>embed</em> photos in the
        email body (click the inline-image button in compose, or drag the
        file directly into the message text). HEIC can't be embedded — only
        attached. JPG can do both.
      </p>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-bold mb-4">Pro tip: smaller files attach faster</h2>
      <p class="text-[var(--color-muted)] leading-relaxed mb-3">
        Gmail's attachment limit is 25MB. iPhone HEIC photos average 1.5-3MB
        each, but RAW or burst-mode files can hit 10MB+. Converting to JPG at
        quality 0.85 typically drops file size by 30-40%, letting you attach
        more photos per email.
      </p>
      <p class="text-[var(--color-muted)] leading-relaxed">
        Use the quality slider in {site.name} to pick a sweet spot. 0.85 is
        visually identical to the original for most photos.
      </p>
    </section>

    <div class="text-center mt-12">
      <a
        href={b("/")}
        class="inline-block px-6 py-3 rounded-lg bg-[var(--color-accent)] text-[var(--color-accent-fg)] font-semibold hover:bg-[var(--color-accent-hover)] transition-colors"
      >
        Convert HEIC for Gmail →
      </a>
    </div>
  </div>
</Layout>
