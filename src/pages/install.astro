---
import Layout from "../layouts/Layout.astro";
import { site } from "../site.config";
import { b } from "../lib/baseUrl";
import { breadcrumb } from "../lib/breadcrumb";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: `Install ${site.name} as an app on Android, iOS, or desktop`,
  description: `Step-by-step guide to install ${site.name} as a Progressive Web App. No app store, no download, ~5 seconds.`,
  totalTime: "PT1M",
  step: [
    { "@type": "HowToStep", position: 1, name: "Open in your browser", text: `Visit ${site.domain} in Chrome, Edge, Safari, or any modern mobile browser.` },
    { "@type": "HowToStep", position: 2, name: "Tap install or share", text: "On Android Chrome: tap Menu → Install app. On iOS Safari: tap Share → Add to Home Screen. On desktop Chrome/Edge: click the install icon in the address bar." },
    { "@type": "HowToStep", position: 3, name: "Confirm", text: `Your phone or computer adds a ${site.name} icon to the home screen, dock, or app drawer.` },
    { "@type": "HowToStep", position: 4, name: "Done", text: `Open ${site.name} like any other app. It works offline. HEIC files can now be shared into ${site.name} from your photos app.` },
  ],
};

const breadcrumbLd = breadcrumb({ name: "Install", path: "/install" });
---

<Layout
  title={`Install ${site.name} — HEIC converter on your home screen, no app store`}
  description={`Install ${site.name} as an app on Android, iPhone, Mac, Windows, or Linux. No app store, no download. ~5 seconds. Then ${site.name} appears in your share sheet so you can convert HEIC files in two taps.`}
  jsonLd={[jsonLd, breadcrumbLd]}
>
  <div class="max-w-4xl mx-auto px-6 py-12 sm:py-16">
    <header class="mb-12 text-center">
      <p class="text-sm text-[var(--color-muted)] mb-2">
        <a href={b("/")} class="hover:text-[var(--color-fg)]">{site.name}</a>
        <span class="mx-1">/</span>
        <span>Install</span>
      </p>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">
        Install {site.name}.
      </h1>
      <p class="text-lg text-[var(--color-muted)] max-w-2xl mx-auto">
        No app store. No download. One tap and {site.name} is on your home
        screen — ready to convert HEIC photos in two taps from anywhere.
      </p>

      <!-- Trust chips -->
      <ul class="mt-8 flex flex-wrap gap-x-5 gap-y-2 justify-center text-sm text-[var(--color-muted)]">
        <li class="flex items-center gap-1.5">
          <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
          ~5 second install
        </li>
        <li class="flex items-center gap-1.5">
          <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
          No permissions
        </li>
        <li class="flex items-center gap-1.5">
          <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
          Auto-updates
        </li>
        <li class="flex items-center gap-1.5">
          <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
          ~2 MB on disk
        </li>
      </ul>
    </header>

    <!-- Per-platform install steps -->
    <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      <!-- Android -->
      <article class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]">
        <div class="flex items-center gap-3 mb-4">
          <svg viewBox="0 0 24 24" class="w-7 h-7 text-[var(--color-accent)]" fill="currentColor" aria-hidden="true">
            <path d="M17.6 9.48l1.84-3.18a.39.39 0 00-.14-.53.39.39 0 00-.54.14L16.93 9.1A11.7 11.7 0 0012 8a11.7 11.7 0 00-4.93 1.1L5.24 5.91a.39.39 0 00-.54-.14.39.39 0 00-.14.53L6.4 9.48A10.81 10.81 0 001 18h22a10.81 10.81 0 00-5.4-8.52zM7 15.25a1.25 1.25 0 111.25-1.25A1.25 1.25 0 017 15.25zm10 0A1.25 1.25 0 1118.25 14 1.25 1.25 0 0117 15.25z"/>
          </svg>
          <h2 class="text-lg font-bold">Android</h2>
        </div>
        <p class="text-xs text-[var(--color-muted)] mb-3">Chrome, Edge, Brave, Samsung Internet</p>
        <ol class="space-y-2 text-sm text-[var(--color-muted)]">
          <li><strong class="text-[var(--color-fg)]">1.</strong> Visit {site.domain} in Chrome</li>
          <li><strong class="text-[var(--color-fg)]">2.</strong> Tap the menu (⋮) → <em class="text-[var(--color-fg)]">Install app</em></li>
          <li><strong class="text-[var(--color-fg)]">3.</strong> Confirm in the prompt</li>
          <li><strong class="text-[var(--color-fg)]">4.</strong> {site.shortName} icon appears in your app drawer</li>
        </ol>
        <p class="mt-3 text-xs text-[var(--color-muted)] italic">
          Bonus: long-press any HEIC photo → Share → {site.shortName} converts it instantly.
        </p>
      </article>

      <!-- iOS -->
      <article class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]">
        <div class="flex items-center gap-3 mb-4">
          <svg viewBox="0 0 24 24" class="w-7 h-7 text-[var(--color-accent)]" fill="currentColor" aria-hidden="true">
            <path d="M17.05 12.04c-.03-3.06 2.49-4.53 2.6-4.6-1.42-2.08-3.63-2.36-4.42-2.4-1.88-.19-3.66 1.11-4.62 1.11-.96 0-2.41-1.08-3.97-1.05-2.04.03-3.93 1.18-4.98 3.01-2.12 3.68-.54 9.13 1.54 12.12 1.02 1.46 2.23 3.1 3.82 3.04 1.54-.06 2.12-.99 3.98-.99 1.86 0 2.39.99 4.01.95 1.65-.03 2.71-1.49 3.72-2.96 1.17-1.7 1.65-3.35 1.67-3.43-.04-.02-3.21-1.23-3.24-4.88zM14.5 3.55c.84-1.03 1.41-2.45 1.25-3.87-1.21.05-2.69.81-3.56 1.83-.78.91-1.46 2.36-1.28 3.74 1.35.1 2.73-.69 3.59-1.7z"/>
          </svg>
          <h2 class="text-lg font-bold">iPhone / iPad</h2>
        </div>
        <p class="text-xs text-[var(--color-muted)] mb-3">Safari only</p>
        <ol class="space-y-2 text-sm text-[var(--color-muted)]">
          <li><strong class="text-[var(--color-fg)]">1.</strong> Visit {site.domain} in Safari</li>
          <li><strong class="text-[var(--color-fg)]">2.</strong> Tap the Share button (square + arrow)</li>
          <li><strong class="text-[var(--color-fg)]">3.</strong> Scroll down → <em class="text-[var(--color-fg)]">Add to Home Screen</em></li>
          <li><strong class="text-[var(--color-fg)]">4.</strong> Tap Add → icon appears on your home screen</li>
        </ol>
        <p class="mt-3 text-xs text-[var(--color-muted)] italic">
          iOS Share Target support varies — best to open {site.shortName} first and pick photos manually.
        </p>
      </article>

      <!-- Desktop -->
      <article class="p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)]">
        <div class="flex items-center gap-3 mb-4">
          <svg viewBox="0 0 24 24" class="w-7 h-7 text-[var(--color-accent)]" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
          <h2 class="text-lg font-bold">Desktop</h2>
        </div>
        <p class="text-xs text-[var(--color-muted)] mb-3">Chrome, Edge, Brave, Arc — Windows / macOS / Linux / ChromeOS</p>
        <ol class="space-y-2 text-sm text-[var(--color-muted)]">
          <li><strong class="text-[var(--color-fg)]">1.</strong> Visit {site.domain}</li>
          <li><strong class="text-[var(--color-fg)]">2.</strong> Click the install icon (⊕) at the right edge of the address bar</li>
          <li><strong class="text-[var(--color-fg)]">3.</strong> Click <em class="text-[var(--color-fg)]">Install</em> in the prompt</li>
          <li><strong class="text-[var(--color-fg)]">4.</strong> {site.shortName} launches in its own window, pinned to taskbar/dock</li>
        </ol>
        <p class="mt-3 text-xs text-[var(--color-muted)] italic">
          Firefox and Safari desktop don't support PWA install — use them as a regular bookmark instead.
        </p>
      </article>
    </section>

    <!-- PWA vs native -->
    <section class="mb-16">
      <h2 class="text-2xl font-bold mb-3 text-center">
        We could ship a native app. We chose not to.
      </h2>
      <p class="text-[var(--color-muted)] text-center max-w-2xl mx-auto mb-8">
        {site.name} is a Progressive Web App. Here's why that's better
        than a native iOS / Android / Windows app for a tool like this.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <div class="p-6 rounded-xl border border-[var(--color-border)]">
          <h3 class="font-bold mb-4 text-[var(--color-error)]">Native app pain</h3>
          <ul class="space-y-2.5 text-sm text-[var(--color-muted)]">
            <li class="flex gap-2">
              <span class="text-[var(--color-error)]" aria-hidden="true">✗</span>
              <span>Goes through App Store / Play Store review (days to weeks)</span>
            </li>
            <li class="flex gap-2">
              <span class="text-[var(--color-error)]" aria-hidden="true">✗</span>
              <span>30-100 MB download</span>
            </li>
            <li class="flex gap-2">
              <span class="text-[var(--color-error)]" aria-hidden="true">✗</span>
              <span>Apple takes 30%, Google takes 30%</span>
            </li>
            <li class="flex gap-2">
              <span class="text-[var(--color-error)]" aria-hidden="true">✗</span>
              <span>Separate codebases per platform = more bugs</span>
            </li>
            <li class="flex gap-2">
              <span class="text-[var(--color-error)]" aria-hidden="true">✗</span>
              <span>Updates require user action</span>
            </li>
          </ul>
        </div>
        <div class="p-6 rounded-xl border border-[var(--color-border)]">
          <h3 class="font-bold mb-4 text-[var(--color-success)]">PWA wins</h3>
          <ul class="space-y-2.5 text-sm text-[var(--color-muted)]">
            <li class="flex gap-2">
              <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
              <span>Ship updates in seconds, no review</span>
            </li>
            <li class="flex gap-2">
              <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
              <span>~2 MB total (HTML + JS + WASM)</span>
            </li>
            <li class="flex gap-2">
              <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
              <span>No platform tax — 100% free forever</span>
            </li>
            <li class="flex gap-2">
              <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
              <span>One codebase, same behavior on every device</span>
            </li>
            <li class="flex gap-2">
              <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
              <span>Auto-updates next time you open it</span>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="text-center">
      <a
        href={b("/")}
        class="inline-block px-6 py-3 rounded-lg bg-[var(--color-accent)] text-[var(--color-accent-fg)] font-semibold hover:bg-[var(--color-accent-hover)] transition-colors"
      >
        Open {site.name} to install →
      </a>
    </div>
  </div>
</Layout>
