---
import Layout from "../layouts/Layout.astro";
import { site } from "../site.config";
import { b } from "../lib/baseUrl";
import DropZone from "../components/DropZone.astro";
import FormatToggle from "../components/FormatToggle.astro";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: site.name,
  url: site.url,
  description: site.description,
  applicationCategory: "MultimediaApplication",
  operatingSystem: "Any (browser-based)",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  featureList: [
    "Convert HEIC to JPG, PNG, WebP, or AVIF instantly",
    "Adjustable quality slider for lossy formats",
    "Unlimited batch size — no daily caps",
    "Zero file upload — runs entirely in your browser",
    "No signup, no ads, no watermark, no premium tier",
    "Free forever — not 'free for now, paid later'",
    "Works on iPhone, Android, Mac, Windows, Linux, Chromebook",
  ],
};
---

<Layout jsonLd={jsonLd}>
  <div class="px-6 py-12 sm:py-16">
    <!-- Hero -->
    <section class="max-w-3xl mx-auto text-center mb-12">
      <a
        href={b("/free-forever")}
        class="inline-flex items-center gap-2 rounded-full border border-[var(--color-accent)] bg-[var(--color-accent)]/[0.08] px-3 py-1 text-xs font-semibold text-[var(--color-accent)] hover:bg-[var(--color-accent)]/[0.14] transition-colors mb-6"
      >
        <span class="size-1.5 rounded-full bg-[var(--color-accent)]" aria-hidden="true"></span>
        Free forever · no signup · nothing uploads
      </a>

      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight mb-5">
        Drop iPhone photos.<br />
        <span class="text-[var(--color-accent)]">Get JPG, PNG, WebP, AVIF.</span><br />
        <span class="text-[var(--color-accent)]">Instantly.</span>
      </h1>

      <p class="text-lg text-[var(--color-muted)] mb-7 max-w-2xl mx-auto">
        Convert HEIC to four formats right in your browser. Adjustable quality.
        Unlimited batch. Zero upload. Your photos never leave your device.
      </p>

      <!-- Format toggle: full user control -->
      <div class="flex flex-col items-center gap-2 mb-8">
        <FormatToggle />
        <p id="png-hint" class="text-xs text-[var(--color-muted)] hidden">
          PNG is lossless — output files will be larger (~3-5× the original).
        </p>
      </div>
    </section>

    <!-- Converter widget -->
    <DropZone />

    <!-- Trust signals -->
    <ul class="max-w-3xl mx-auto mt-12 flex flex-wrap gap-x-6 gap-y-2 justify-center text-sm text-[var(--color-muted)]">
      <li class="flex items-center gap-2">
        <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
        Unlimited files
      </li>
      <li class="flex items-center gap-2">
        <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
        4 formats: JPG · PNG · WebP · AVIF
      </li>
      <li class="flex items-center gap-2">
        <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
        No signup
      </li>
      <li class="flex items-center gap-2">
        <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
        No ads
      </li>
      <li class="flex items-center gap-2">
        <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
        Works offline
      </li>
    </ul>

    <!-- More HEIC tools — surface inspector pages prominently on home + mobile,
         since the desktop nav links are hidden on small screens.
         3-up on md+, stacked on mobile. -->
    <section class="max-w-5xl mx-auto mt-20" aria-labelledby="more-tools-heading">
      <div class="text-center mb-8">
        <h2 id="more-tools-heading" class="text-2xl sm:text-3xl font-extrabold tracking-tight mb-3">
          More HEIC tools
        </h2>
        <p class="text-[var(--color-muted)] max-w-2xl mx-auto">
          Need to peek inside a HEIC, read its EXIF, or strip metadata before
          sharing? All client-side, all free, all unlimited.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <!-- HEIC Viewer -->
        <a
          href={b("/heic-viewer")}
          class="group relative block p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)]/[0.04] transition-colors no-underline"
        >
          <div class="flex items-center justify-center w-11 h-11 rounded-lg bg-[var(--color-accent)]/[0.10] text-[var(--color-accent)] mb-4">
            <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </div>
          <h3 class="text-base font-bold text-[var(--color-fg)] mb-1.5">
            HEIC Viewer
          </h3>
          <p class="text-sm text-[var(--color-muted)] mb-4">
            Preview a HEIC in your browser without converting it. Drag-drop,
            full quality, no upload.
          </p>
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-[var(--color-accent)] group-hover:text-[var(--color-accent-hover)]">
            Open viewer
            <svg viewBox="0 0 24 24" class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </span>
        </a>

        <!-- HEIC EXIF -->
        <a
          href={b("/heic-exif")}
          class="group relative block p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)]/[0.04] transition-colors no-underline"
        >
          <div class="flex items-center justify-center w-11 h-11 rounded-lg bg-[var(--color-accent)]/[0.10] text-[var(--color-accent)] mb-4">
            <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="16" rx="2"/>
              <path d="M7 9h10M7 13h10M7 17h6"/>
            </svg>
          </div>
          <h3 class="text-base font-bold text-[var(--color-fg)] mb-1.5">
            HEIC EXIF Reader
          </h3>
          <p class="text-sm text-[var(--color-muted)] mb-4">
            Read camera, lens, GPS, and date metadata embedded inside a HEIC.
            Nothing decoded, nothing uploaded.
          </p>
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-[var(--color-accent)] group-hover:text-[var(--color-accent-hover)]">
            Open EXIF reader
            <svg viewBox="0 0 24 24" class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </span>
        </a>

        <!-- Strip EXIF -->
        <a
          href={b("/strip-heic-exif")}
          class="group relative block p-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)]/[0.04] transition-colors no-underline"
        >
          <div class="flex items-center justify-center w-11 h-11 rounded-lg bg-[var(--color-accent)]/[0.10] text-[var(--color-accent)] mb-4">
            <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 22s8-4 8-12V5l-8-3-8 3v5c0 8 8 12 8 12z"/>
              <path d="M9 12l2 2 4-4"/>
            </svg>
          </div>
          <h3 class="text-base font-bold text-[var(--color-fg)] mb-1.5">
            Strip EXIF Metadata
          </h3>
          <p class="text-sm text-[var(--color-muted)] mb-4">
            Remove GPS and camera metadata before sharing. Outputs JPGs with
            zero embedded EXIF.
          </p>
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-[var(--color-accent)] group-hover:text-[var(--color-accent-hover)]">
            Strip metadata
            <svg viewBox="0 0 24 24" class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      </div>
    </section>

    <!-- Why it's different -->
    <section class="max-w-4xl mx-auto mt-24 grid grid-cols-1 md:grid-cols-3 gap-8">
      <article class="text-center">
        <div class="text-3xl mb-3" aria-hidden="true">🔒</div>
        <h2 class="text-lg font-bold mb-2">Nothing uploads</h2>
        <p class="text-sm text-[var(--color-muted)]">
          Conversion runs entirely in your browser using WebAssembly. Your
          photos never touch our servers — there are no servers to touch them.
        </p>
      </article>

      <article class="text-center">
        <div class="text-3xl mb-3" aria-hidden="true">⚡</div>
        <h2 class="text-lg font-bold mb-2">Batch unlimited</h2>
        <p class="text-sm text-[var(--color-muted)]">
          Drop 200 HEICs at once. They convert in parallel using your device's
          CPU. Most online tools cap you at 5 or 25 files per day.
        </p>
      </article>

      <article class="text-center">
        <div class="text-3xl mb-3" aria-hidden="true">🎁</div>
        <h2 class="text-lg font-bold mb-2">Actually free</h2>
        <p class="text-sm text-[var(--color-muted)]">
          No signup, no email capture, no "free trial that becomes a
          subscription," no watermark on output. Lifetime free, forever.
        </p>
      </article>
    </section>

    <!-- Compare with competitors -->
    <section class="max-w-4xl mx-auto mt-24 px-2">
      <h2 class="text-2xl sm:text-3xl font-extrabold tracking-tight text-center mb-3">
        How {site.name} compares
      </h2>
      <p class="text-[var(--color-muted)] text-center max-w-2xl mx-auto mb-8">
        Other "free" HEIC converters add ads, caps, signups, or quietly
        upload your photos. Here's the honest comparison.
      </p>

      <div class="overflow-x-auto rounded-xl border border-[var(--color-border)]">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-[var(--color-border)] bg-[var(--color-surface)]">
              <th class="text-left py-3 px-4 font-semibold">Tool</th>
              <th class="text-left py-3 px-4 font-semibold">Upload?</th>
              <th class="text-left py-3 px-4 font-semibold">Free tier limit</th>
              <th class="text-left py-3 px-4 font-semibold">Price for "no limit"</th>
              <th class="text-left py-3 px-4 font-semibold">Ads?</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-[var(--color-border)]">
              <td class="py-3 px-4 text-[var(--color-muted)]">iloveimg.com</td>
              <td class="py-3 px-4 text-[var(--color-muted)]">Uploads to server</td>
              <td class="py-3 px-4 text-[var(--color-muted)]">5 files per batch</td>
              <td class="py-3 px-4 text-[var(--color-muted)]">$4/mo Premium</td>
              <td class="py-3 px-4 text-[var(--color-muted)]">Yes</td>
            </tr>
            <tr class="border-b border-[var(--color-border)]">
              <td class="py-3 px-4 text-[var(--color-muted)]">cloudconvert.com</td>
              <td class="py-3 px-4 text-[var(--color-muted)]">Uploads to server</td>
              <td class="py-3 px-4 text-[var(--color-muted)]">25 per day</td>
              <td class="py-3 px-4 text-[var(--color-muted)]">$8+/mo</td>
              <td class="py-3 px-4 text-[var(--color-muted)]">No</td>
            </tr>
            <tr class="border-b border-[var(--color-border)]">
              <td class="py-3 px-4 text-[var(--color-muted)]">online-convert.com</td>
              <td class="py-3 px-4 text-[var(--color-muted)]">Uploads to server</td>
              <td class="py-3 px-4 text-[var(--color-muted)]">100 MB / file</td>
              <td class="py-3 px-4 text-[var(--color-muted)]">$7+/mo</td>
              <td class="py-3 px-4 text-[var(--color-muted)]">Yes (heavy)</td>
            </tr>
            <tr class="border-b border-[var(--color-border)]">
              <td class="py-3 px-4 text-[var(--color-muted)]">heictojpg.com</td>
              <td class="py-3 px-4 text-[var(--color-muted)]">Uploads to server</td>
              <td class="py-3 px-4 text-[var(--color-muted)]">30 per batch</td>
              <td class="py-3 px-4 text-[var(--color-muted)]">N/A (capped)</td>
              <td class="py-3 px-4 text-[var(--color-muted)]">Yes</td>
            </tr>
            <tr
              class="border-t-2 border-[var(--color-accent)]"
              style="background-color: color-mix(in srgb, var(--color-accent) 14%, transparent);"
            >
              <td class="py-3 px-4 font-bold text-[var(--color-accent)]">
                <span class="inline-flex items-center gap-2">
                  <span class="size-2 rounded-full bg-[var(--color-accent)]" aria-hidden="true"></span>
                  {site.name}
                </span>
              </td>
              <td class="py-3 px-4 font-semibold text-[var(--color-fg)]">
                Never — browser-only
              </td>
              <td class="py-3 px-4 font-semibold text-[var(--color-fg)]">
                Unlimited
              </td>
              <td class="py-3 px-4 font-semibold text-[var(--color-fg)]">
                <span class="inline-flex items-center gap-1">
                  $0 · forever
                  <a
                    href={b("/free-forever")}
                    class="text-xs text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] underline"
                    title="Read our free-forever pledge"
                  >
                    (why?)
                  </a>
                </span>
              </td>
              <td class="py-3 px-4 font-semibold text-[var(--color-fg)]">
                No
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="text-xs text-[var(--color-muted)] text-center mt-4">
        Comparison data verified 2026-06. Competitor terms may have changed since.
      </p>
    </section>

    <!-- Platform-specific quick links -->
    <section class="max-w-4xl mx-auto mt-20 text-center">
      <h2 class="text-2xl font-extrabold tracking-tight mb-3">
        On a specific device?
      </h2>
      <p class="text-[var(--color-muted)] mb-6 max-w-2xl mx-auto">
        Quick guides for opening HEIC files on every platform that doesn't
        support them natively.
      </p>
      <div class="flex flex-wrap gap-2 justify-center mb-8">
        <a
          href={b("/heic-to-jpg-windows")}
          class="px-4 py-2 rounded-md border border-[var(--color-border)] hover:bg-[var(--color-surface)] text-sm text-[var(--color-fg)] transition-colors"
        >
          HEIC on Windows
        </a>
        <a
          href={b("/heic-to-jpg-mac")}
          class="px-4 py-2 rounded-md border border-[var(--color-border)] hover:bg-[var(--color-surface)] text-sm text-[var(--color-fg)] transition-colors"
        >
          HEIC on Mac
        </a>
        <a
          href={b("/heic-to-jpg-chromebook")}
          class="px-4 py-2 rounded-md border border-[var(--color-border)] hover:bg-[var(--color-surface)] text-sm text-[var(--color-fg)] transition-colors"
        >
          HEIC on Chromebook
        </a>
        <a
          href={b("/heic-to-jpg-android")}
          class="px-4 py-2 rounded-md border border-[var(--color-border)] hover:bg-[var(--color-surface)] text-sm text-[var(--color-fg)] transition-colors"
        >
          HEIC on Android
        </a>
      </div>

      <p class="text-sm text-[var(--color-muted)]">
        Or try the new formats —
        <a
          href={b("/heic-to-webp")}
          class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] underline"
        >
          HEIC → WebP
        </a>{" "}
        ·{" "}
        <a
          href={b("/heic-to-avif")}
          class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] underline"
        >
          HEIC → AVIF
        </a>{" "}
        ·{" "}
        <a
          href={b("/heic-to-png")}
          class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] underline"
        >
          HEIC → PNG
        </a>
      </p>
    </section>
  </div>
</Layout>
