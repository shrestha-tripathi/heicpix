---
import Layout from "../layouts/Layout.astro";
import { site } from "../site.config";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: site.name,
  url: site.url,
  description: site.description,
  applicationCategory: "MultimediaApplication",
  operatingSystem: "Any (browser-based)",
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD",
  },
  featureList: [
    "Convert HEIC to JPG or PNG instantly",
    "Unlimited batch size",
    "Zero file upload — runs entirely in your browser",
    "No signup, no ads, no watermark",
    "Works on iPhone, Android, Mac, Windows, Linux",
  ],
};
---

<Layout jsonLd={jsonLd}>
  <main class="flex-1 flex flex-col items-center justify-center px-6 py-16">
    <!-- Hero -->
    <section class="max-w-3xl w-full text-center">
      <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold tracking-tight mb-6">
        Drop iPhone photos.<br />
        <span class="text-[var(--color-accent)]">Get JPGs or PNGs.</span><br />
        <span class="text-[var(--color-accent)]">Instantly.</span>
      </h1>

      <p class="text-lg sm:text-xl text-[var(--color-muted)] mb-10 max-w-2xl mx-auto">
        Convert HEIC to JPG or PNG right in your browser. Unlimited batch,
        zero upload, no signup. Your photos never leave your device.
      </p>

      <!-- Dropzone placeholder (logic ships in v0.2) -->
      <div
        class="border-2 border-dashed border-[var(--color-border)] rounded-2xl p-12 sm:p-16 bg-[var(--color-surface)] mb-8"
        aria-label="Drop zone (coming soon)"
      >
        <div class="text-6xl mb-4" aria-hidden="true">⬇</div>
        <p class="text-lg font-semibold mb-2">Drop .heic files here</p>
        <p class="text-sm text-[var(--color-muted)]">
          Or tap to pick photos — <em>(converter ships in v0.2)</em>
        </p>
      </div>

      <!-- Trust signals -->
      <ul class="flex flex-wrap gap-x-6 gap-y-2 justify-center text-sm text-[var(--color-muted)]">
        <li class="flex items-center gap-2">
          <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
          Unlimited files
        </li>
        <li class="flex items-center gap-2">
          <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
          No signup
        </li>
        <li class="flex items-center gap-2">
          <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
          No ads
        </li>
        <li class="flex items-center gap-2">
          <span class="text-[var(--color-success)]" aria-hidden="true">✓</span>
          Works offline
        </li>
      </ul>
    </section>

    <!-- Why it's different -->
    <section class="max-w-4xl w-full mt-24 grid grid-cols-1 md:grid-cols-3 gap-8">
      <article class="text-center">
        <div class="text-3xl mb-3" aria-hidden="true">🔒</div>
        <h2 class="text-lg font-bold mb-2">Nothing uploads</h2>
        <p class="text-sm text-[var(--color-muted)]">
          Conversion runs entirely in your browser using WebAssembly. Your
          photos never touch our servers — there are no servers to touch them.
        </p>
      </article>

      <article class="text-center">
        <div class="text-3xl mb-3" aria-hidden="true">⚡</div>
        <h2 class="text-lg font-bold mb-2">Batch unlimited</h2>
        <p class="text-sm text-[var(--color-muted)]">
          Drop 200 HEICs at once. They convert in parallel using your device's
          CPU. Most online tools cap you at 5 or 25 files per day.
        </p>
      </article>

      <article class="text-center">
        <div class="text-3xl mb-3" aria-hidden="true">🎁</div>
        <h2 class="text-lg font-bold mb-2">Actually free</h2>
        <p class="text-sm text-[var(--color-muted)]">
          No signup, no email capture, no "free trial that becomes a
          subscription," no watermark on output. Lifetime free, forever.
        </p>
      </article>
    </section>

    <!-- Footer -->
    <footer class="mt-32 text-center text-sm text-[var(--color-muted)]">
      <p>
        Built by
        <a
          href={site.org.url}
          class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] underline"
          rel="noopener"
        >
          {site.org.name}
        </a>
        — privacy-first tools that work without the cloud.
      </p>
    </footer>
  </main>
</Layout>
