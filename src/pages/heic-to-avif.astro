---
import Layout from "../layouts/Layout.astro";
import { site } from "../site.config";
import { b } from "../lib/baseUrl";
import { breadcrumb } from "../lib/breadcrumb";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: `Convert HEIC to AVIF for free with ${site.name}`,
  description: `Convert iPhone HEIC photos to AVIF (the most efficient image codec, used by Netflix and YouTube). Half the size of JPG. Free forever, no upload, no signup.`,
  totalTime: "PT20S",
  step: [
    {
      "@type": "HowToStep",
      name: "Open the converter in Chrome or Edge",
      text: `AVIF encoding requires Chrome 124+ or Edge 124+ (released April 2024). Firefox and Safari can DISPLAY AVIF but can't yet ENCODE it in-browser.`,
    },
    {
      "@type": "HowToStep",
      name: "Choose AVIF as the output format",
      text: `Click "AVIF" in the format toggle. If your browser doesn't support it, the button will be disabled with a tooltip — switch to WebP instead (nearly as small, works everywhere).`,
    },
    {
      "@type": "HowToStep",
      name: "Adjust quality (lower = smaller)",
      text: `AVIF is so efficient you can drop the quality slider to 60-70% and still get visually-lossless results. Default 65%.`,
    },
    {
      "@type": "HowToStep",
      name: "Drop your HEIC files",
      text: `Drag iPhone .heic / .heif files onto the dropzone. Decoding is fast; encoding AVIF is slower than JPG (3-5× slower per file).`,
    },
    {
      "@type": "HowToStep",
      name: "Save the AVIF files",
      text: `Download a zip, save to folder, or share — whatever works on your device. Filenames preserved.`,
    },
  ],
};

const breadcrumbLd = breadcrumb({ name: "HEIC → AVIF", path: "/heic-to-avif" });
---

<Layout
  title={`Convert HEIC to AVIF free — ${site.name}`}
  description={`Free HEIC to AVIF converter. Browser-only — nothing uploads. Half the size of JPG at the same quality. Works in Chrome 124+, no signup, no limits.`}
  jsonLd={[jsonLd, breadcrumbLd]}
>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <p class="text-sm text-[var(--color-muted)] mb-4">
      <a href={b("/")} class="hover:text-[var(--color-fg)]">Home</a>
      <span class="mx-2">/</span>
      <span>HEIC → AVIF</span>
    </p>

    <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">
      HEIC to AVIF, <span class="text-[var(--color-accent)]">free forever</span>.
    </h1>
    <p class="text-lg text-[var(--color-muted)] mb-8">
      The most efficient image format on the web. Half the size of JPG at the
      same visual quality. Right in your browser — nothing uploads.
    </p>

    <div class="rounded-lg border border-[var(--color-warn,_var(--color-accent))] bg-[var(--color-accent)]/[0.06] p-5 mb-10">
      <p class="text-sm font-semibold text-[var(--color-fg)] mb-2">
        ⚠ Browser requirement
      </p>
      <p class="text-sm text-[var(--color-muted)]">
        AVIF <em>encoding</em> in the browser requires{" "}
        <strong>Chrome 124+ or Edge 124+</strong> (April 2024). Firefox and
        Safari can show AVIF images but can't yet encode them. On those
        browsers, the AVIF button will be disabled — pick{" "}
        <a
          href={b("/heic-to-webp")}
          class="underline hover:text-[var(--color-accent)]"
        >
          WebP
        </a>{" "}
        instead.
      </p>
    </div>

    <div class="rounded-lg border border-[var(--color-accent)] bg-[var(--color-accent)]/[0.08] p-5 mb-10">
      <p class="text-sm font-semibold text-[var(--color-fg)] mb-2">
        → Just want to convert?
      </p>
      <p class="text-sm text-[var(--color-muted)] mb-3">
        Skip the explainer. Open the converter, pick AVIF, drop your files.
      </p>
      <a
        href={b("/")}
        class="inline-flex items-center gap-2 rounded-md bg-[var(--color-accent)] px-4 py-2 text-sm font-semibold text-[var(--color-accent-fg)] hover:bg-[var(--color-accent-hover)] transition-colors"
      >
        Open converter →
      </a>
    </div>

    <h2 class="text-2xl font-bold tracking-tight mb-3 mt-10">
      Why AVIF?
    </h2>
    <ul class="space-y-2 text-[var(--color-fg)]">
      <li>
        <strong>Smallest files by far</strong> — typically 50% smaller than JPG,
        20-30% smaller than WebP, at the same visual quality.
      </li>
      <li>
        <strong>Built on AV1</strong> — the codec Netflix, YouTube, and Vimeo
        use for video. Royalty-free, open standard.
      </li>
      <li>
        <strong>Display support is now universal</strong> — every modern browser
        can show AVIF (Chrome 85+, Firefox 93+, Safari 16+, Edge 121+).
      </li>
      <li>
        <strong>HDR-ready</strong> — AVIF supports 10-bit and 12-bit color, so
        your iPhone HDR photos look the way they're supposed to look.
      </li>
    </ul>

    <h2 class="text-2xl font-bold tracking-tight mb-3 mt-10">
      AVIF vs WebP vs JPG — pick by use case
    </h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b border-[var(--color-border)]">
            <th class="text-left py-2 pr-4 font-semibold">Use case</th>
            <th class="text-left py-2 font-semibold">Best pick</th>
          </tr>
        </thead>
        <tbody class="text-[var(--color-muted)]">
          <tr class="border-b border-[var(--color-border)]/50">
            <td class="py-3 pr-4">Sharing on WhatsApp / iMessage / Email</td>
            <td class="py-3 font-semibold text-[var(--color-fg)]">JPG</td>
          </tr>
          <tr class="border-b border-[var(--color-border)]/50">
            <td class="py-3 pr-4">Posting on a website or blog</td>
            <td class="py-3 font-semibold text-[var(--color-fg)]">AVIF (best)</td>
          </tr>
          <tr class="border-b border-[var(--color-border)]/50">
            <td class="py-3 pr-4">Cross-browser web image (no AVIF fallback)</td>
            <td class="py-3 font-semibold text-[var(--color-fg)]">WebP</td>
          </tr>
          <tr class="border-b border-[var(--color-border)]/50">
            <td class="py-3 pr-4">Printing</td>
            <td class="py-3 font-semibold text-[var(--color-fg)]">JPG or PNG</td>
          </tr>
          <tr>
            <td class="py-3 pr-4">Editing in Photoshop / Pixelmator</td>
            <td class="py-3 font-semibold text-[var(--color-fg)]">PNG (lossless)</td>
          </tr>
        </tbody>
      </table>
    </div>

    <h2 class="text-2xl font-bold tracking-tight mb-3 mt-10">
      Why is AVIF encoding slower than JPG?
    </h2>
    <p class="text-[var(--color-fg)]">
      AVIF squeezes more out of each byte by doing more computational work per
      pixel — analyzing neighboring blocks, predicting from motion vectors
      (yes, image AVIF uses video-codec tricks). On a typical 12 MP iPhone
      photo, expect 1-2 seconds per file vs ~200ms for JPG. The output is
      worth it: half the file size for the same visual quality.
    </p>

    <h2 class="text-2xl font-bold tracking-tight mb-3 mt-10">
      Is it really free?
    </h2>
    <p class="text-[var(--color-fg)]">
      Yes. Forever. No signup, no daily caps, no ads, no watermark, no premium
      tier locked behind AVIF.{" "}
      <a
        href={b("/free-forever")}
        class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] underline"
      >
        Read why we're committed to that →
      </a>
    </p>

    <div class="mt-12 pt-8 border-t border-[var(--color-border)]">
      <a
        href={b("/")}
        class="inline-flex items-center gap-2 rounded-md bg-[var(--color-accent)] px-5 py-2.5 text-base font-semibold text-[var(--color-accent-fg)] hover:bg-[var(--color-accent-hover)] transition-colors"
      >
        Open converter →
      </a>
    </div>
  </article>
</Layout>
