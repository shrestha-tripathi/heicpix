---
import Layout from "../layouts/Layout.astro";
import { site } from "../site.config";
import { b } from "../lib/baseUrl";
import { breadcrumb } from "../lib/breadcrumb";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to upload iPhone HEIC photos to Canva",
  description: "Canva's upload doesn't accept HEIC. Convert to JPG in your browser, then drag into Canva.",
  totalTime: "PT30S",
  step: [
    { "@type": "HowToStep", position: 1, name: `Open ${site.name}`, text: `Visit ${site.domain}.` },
    { "@type": "HowToStep", position: 2, name: "Drop your HEIC photos", text: "Drag-and-drop or pick from your phone/computer." },
    { "@type": "HowToStep", position: 3, name: "Pick JPG (or PNG for transparency)", text: "JPG for photos, PNG if you need transparent areas." },
    { "@type": "HowToStep", position: 4, name: "Upload to Canva", text: "Drag the converted file into the Canva uploads panel. It appears in your library." },
  ],
};

const breadcrumbLd = breadcrumb({ name: "HEIC for Canva", path: "/heic-for-canva" });
---

<Layout
  title="HEIC for Canva — upload iPhone photos that Canva will accept"
  description="Canva rejects iPhone .heic files with 'unsupported format'. Convert HEIC to JPG or PNG in your browser, then upload to Canva. Free, no signup, batch supported."
  jsonLd={[jsonLd, breadcrumbLd]}
>
  <div class="max-w-3xl mx-auto px-6 py-12 sm:py-16">
    <header class="mb-10">
      <p class="text-sm text-[var(--color-muted)] mb-2">
        <a href={b("/")} class="hover:text-[var(--color-fg)]">{site.name}</a>
        <span class="mx-1">/</span>
        <span>HEIC for Canva</span>
      </p>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-4">
        Upload iPhone HEIC to Canva
      </h1>
      <p class="text-lg text-[var(--color-muted)]">
        Canva's media uploader doesn't recognize .heic files from your iPhone
        camera roll. Convert to JPG (or PNG) in your browser, then upload them
        normally — and they appear in your media library.
      </p>
    </header>

    <section class="mb-10">
      <h2 class="text-2xl font-bold mb-4">The fix</h2>
      <p class="text-[var(--color-muted)] leading-relaxed mb-4">
        Drop your HEIC into {site.name}, pick JPG, then drag the result into
        Canva's "Uploads" tab. They appear in your media library and you can
        use them in any design.
      </p>
      <a
        href={b("/")}
        class="inline-block px-6 py-3 rounded-lg bg-[var(--color-accent)] text-[var(--color-accent-fg)] font-semibold hover:bg-[var(--color-accent-hover)] transition-colors"
      >
        Convert HEIC for Canva →
      </a>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-bold mb-4">Why does Canva reject HEIC?</h2>
      <p class="text-[var(--color-muted)] leading-relaxed mb-3">
        Canva's editor runs in the browser using WebGL — and browser image
        decoders historically didn't include HEIC. Canva's web upload accepts
        JPG, PNG, GIF, WebP, SVG, and HEIF on Safari (which has native HEIF
        support), but rejects HEIC everywhere else.
      </p>
      <p class="text-[var(--color-muted)] leading-relaxed">
        Converting to JPG once gives you a universal asset that uploads in
        every Canva client — web, desktop app, mobile app.
      </p>
    </section>

    <section class="mb-10">
      <h2 class="text-2xl font-bold mb-4">Which format for Canva?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="p-4 rounded-xl border border-[var(--color-border)]">
          <h3 class="font-bold mb-1">JPG</h3>
          <p class="text-sm text-[var(--color-muted)]">Best for photos. Small file size, fast upload, looks identical to HEIC at default quality.</p>
        </div>
        <div class="p-4 rounded-xl border border-[var(--color-border)]">
          <h3 class="font-bold mb-1">PNG</h3>
          <p class="text-sm text-[var(--color-muted)]">Pick this if you need to overlay the photo on a transparent background or composite cleanly.</p>
        </div>
        <div class="p-4 rounded-xl border border-[var(--color-border)]">
          <h3 class="font-bold mb-1">WebP</h3>
          <p class="text-sm text-[var(--color-muted)]">Canva supports WebP uploads. Even smaller than JPG. Great for batch uploads on slow internet.</p>
        </div>
        <div class="p-4 rounded-xl border border-[var(--color-border)]">
          <h3 class="font-bold mb-1">AVIF</h3>
          <p class="text-sm text-[var(--color-muted)]">Not yet supported by Canva uploads — pick JPG/PNG/WebP instead.</p>
        </div>
      </div>
    </section>

    <div class="text-center mt-12">
      <a
        href={b("/")}
        class="inline-block px-6 py-3 rounded-lg bg-[var(--color-accent)] text-[var(--color-accent-fg)] font-semibold hover:bg-[var(--color-accent-hover)] transition-colors"
      >
        Convert HEIC for Canva →
      </a>
    </div>
  </div>
</Layout>
