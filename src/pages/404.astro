---
import Layout from "../layouts/Layout.astro";
import { b } from "../lib/baseUrl";
---

<Layout
  title="Page not found"
  description="The page you were looking for doesn't exist."
  noindex={true}
>
  <div class="max-w-xl mx-auto px-6 py-24 text-center">
    <p class="text-8xl font-extrabold text-[var(--color-accent)] mb-4">404</p>
    <h1 class="text-3xl font-extrabold tracking-tight mb-4">
      That page doesn't exist.
    </h1>
    <p class="text-[var(--color-muted)] mb-8">
      Maybe a typo? Or maybe we moved it. Either way, here's where to go next:
    </p>
    <div class="flex flex-wrap gap-3 justify-center">
      <a
        href={b("/")}
        class="px-5 py-2.5 rounded-lg bg-[var(--color-accent)] text-[var(--color-accent-fg)] font-semibold hover:bg-[var(--color-accent-hover)]"
      >
        Convert HEIC
      </a>
      <a
        href={b("/faq")}
        class="px-5 py-2.5 rounded-lg border border-[var(--color-border)] hover:bg-[var(--color-surface)] text-[var(--color-fg)] font-semibold"
      >
        Read the FAQ
      </a>
    </div>
  </div>
</Layout>
