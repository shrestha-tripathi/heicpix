# Cloudflare Pages _headers — applied to all routes.
#
# Goal: prevent the *.pages.dev preview domain from getting indexed
# (otherwise it competes with the real domain for SEO + dilutes link equity).
# The real domain doesn't match this pattern; it gets the default headers.

# Block indexing of *.pages.dev previews
https://:project.pages.dev/*
  X-Robots-Tag: noindex, nofollow

# Sensible defaults for everything
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# Service worker — never cache (always check for updates)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Favicon — set explicit MIME type (some CDN configs default to
# application/octet-stream which browsers reject) + cache 30 days
/favicon.ico
  Cache-Control: public, max-age=2592000
  Content-Type: image/x-icon
/favicon.svg
  Cache-Control: public, max-age=2592000
/favicon-32.png
  Cache-Control: public, max-age=2592000

# Apple touch + PWA icons — cache 30 days
/apple-touch-icon.png
  Cache-Control: public, max-age=2592000
/icon-192.png
  Cache-Control: public, max-age=2592000
/icon-512.png
  Cache-Control: public, max-age=2592000
/icon-maskable-512.png
  Cache-Control: public, max-age=2592000

# Manifest — cache lightly
/manifest.webmanifest
  Cache-Control: public, max-age=3600
  Content-Type: application/manifest+json
