# HEICPix — environment variables
# Copy to .env.local for local dev. Set in Cloudflare Pages dashboard for prod.
#
# ⚠️  NEVER set PUBLIC_SITE_URL or PUBLIC_SITE_DOMAIN to a *.pages.dev value
# in the Cloudflare Pages dashboard. The site.config.ts guard will reject
# those silently to prevent canonical-URL poisoning — but it's cleaner to
# just leave them unset and let the defaults apply.

# === Brand strings (override to rebrand) ===
PUBLIC_SITE_NAME="HEICPix"
PUBLIC_SITE_SHORT_NAME="HEICPix"
PUBLIC_SITE_TAGLINE="iPhone HEIC photos to JPG or PNG, in your browser"
PUBLIC_SITE_DESCRIPTION="Convert HEIC to JPG or PNG free in your browser. Drop iPhone HEIC photos, get JPGs or PNGs back. Unlimited batch, zero upload, no signup, no ads. Works on Windows, Mac, Chromebook, Android, every browser."

# === URLs (set after domain purchase) ===
PUBLIC_SITE_URL="https://heicpix.com"
PUBLIC_SITE_DOMAIN="heicpix.com"

# === Owner / parent brand ===
PUBLIC_ORG_NAME="WorksOffline"
PUBLIC_ORG_URL="https://worksoffline.in"
PUBLIC_ORG_LOGO="https://worksoffline.in/favicon.svg"

# === Analytics (production only) ===
# Leave blank in dev — Layout.astro auto-gates on import.meta.env.PROD
PUBLIC_GA4_MEASUREMENT_ID=""

# === Social ===
PUBLIC_TWITTER_HANDLE="@worksoffline"
